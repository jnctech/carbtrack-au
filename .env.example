# Database — SQLite default, swap to Postgres URI for production migration
# Local dev: relative path. Docker: /app/data/carbtrack.db (matches volume mount)
DATABASE_URL=sqlite:///./carbtrack.db

# Anthropic API — required for query builder and field mapping (Phase 3)
ANTHROPIC_API_KEY=sk-ant-xxx

# Sonnet model version — consumed by query builder endpoints only
SONNET_MODEL=claude-sonnet-4-5-20241022

# Logging
LOG_LEVEL=INFO

# Deployment host (used in docker-compose)
DEPLOY_HOST=0.0.0.0

# Open Food Facts barcode fallback (runtime, no auth required)
# Triggered when /foods/barcode/{barcode} misses the local DB.
# Set OFF_FALLBACK_ENABLED=false to disable (e.g. offline environments).
# OFF_USER_AGENT must identify this app per OFF API ToS — include a contact URL/email.
OFF_API_BASE=https://world.openfoodfacts.org/api/v2
OFF_USER_AGENT=CarbTrackAU/0.1 (https://github.com/jnctech/carbtrack-au)
OFF_TIMEOUT=5.0
OFF_FALLBACK_ENABLED=true

# Open Food Facts contribution (POST /foods/contribute → write back to OFF)
# Disabled by default — flip to true once OFF_USERNAME/PASSWORD or app creds set.
# Without auth, OFF accepts anonymous app-tagged contributions (lower trust score).
# When enabled but OFF rejects (network, validation), local staging still succeeds.
OFF_WRITE_BASE=https://world.openfoodfacts.org/cgi
OFF_CONTRIBUTE_ENABLED=false
OFF_APP_NAME=CarbTrackAU
OFF_APP_VERSION=0.1
# OFF_USERNAME=your_off_username
# OFF_PASSWORD=your_off_password
